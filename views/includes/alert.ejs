
<%  if(success && success.length){ %>
   <div class="alert alert-success  alert-dismissible  col-6 offset-3" height="50-px" role="alert">
    <i class="fa-solid fa-square-check fa-fade bg-transparent" style="color: rgb(131, 130, 134);"></i>
  <strong class="bg-transparent"><%= success %> </strong>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
 <% }  %>
<%  if(error && error.length){ %>
   <div class="alert alert-warning alert-dismissible fade show col-6 offset-3" role="alert">
<i class="fa-solid fa-exclamation fa-fade bg-transparent" style="color: rgb(245, 4, 4);"></i>  
<strong class="bg-transparent"><%= error %> </strong>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
 <% }  %>

