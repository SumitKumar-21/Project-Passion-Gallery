<% layout('/layouts/boilerplate') %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Edit <%= info.title %></h3>
    <form method="post" action="/showall/<%=info.id%>?_method=PUT" novalidate class="needs-validation" enctype="multipart/form-data">
      
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          id="title"
          class="form-control"
          type="text"
          name="listing[title]"
          value="<%=info.title %>"
          required
        />
        <div class="valid-feedback">Looks Good!</div>
        <div class="invalid-feedback">Title is most required⚠️</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          class="form-control"
          id="description"
          rows="3"
          name="listing[description]"
          required><%=info.description %></textarea>
        <div class="valid-feedback">Looks Good!</div>
        <div class="invalid-feedback">Description required⚠️</div>
      </div>

      <div class="mb-3">
        <label class="form-label">Current Image</label>
        <div>
          <img src="<%=info.Image.url %>" class="img-thumbnail" style="max-height: 200px;" alt="Current Listing Image">
        </div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Upload New Image</label>
        <input
          id="image"
          class="form-control"
          type="file"
          name="listing[Image]"
        />
        <div class="valid-feedback">Looks Good!</div>
        <div class="invalid-feedback">⚠️</div>
      </div>

      <div class="row mb-3">
        <div class="col-md-4">
          <label for="price" class="form-label">Price</label>
          <input
            id="price"
            class="form-control"
            type="number"
            name="listing[price]"
            value="<%=info.price %>"
            required
          />
          <div class="valid-feedback">Looks Good!</div>
          <div class="invalid-feedback">⚠️Should be valid</div>
        </div>
        <div class="col-md-8">
          <label for="location" class="form-label">Location</label>
          <input
            id="location"
            class="form-control"
            type="text"
            name="listing[location]"
            value="<%=info.location %>"
            required
          />
          <div class="valid-feedback">Looks Good!</div>
          <div class="invalid-feedback">⚠️Should not be empty</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input
          id="country"
          class="form-control"
          type="text"
          name="listing[country]"
          value="<%=info.country %>"
          required
        />
        <div class="valid-feedback">Looks Good!</div>
        <div class="invalid-feedback">⚠️Should not be empty </div>
      </div>

      <button class="btn btn-dark mb-5 mt-2">Submit Change</button>
    </form>
  </div>
</div>
