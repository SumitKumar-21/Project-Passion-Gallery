<% layout('/layouts/boilerplate') %>
<a class="btn btn-dark ms-0 mt-1" href="/showall" role="button">
  <i class="fa-solid fa-arrow-left bg-transparent fs-6 me-1"></i>
  Back
</a>
<div class="container py-4">
  <div class="row justify-content-center">

    <!-- Listing -->
    <div class="col-lg-8">

      <div class="card shadow border-0 rounded-4 overflow-hidden">

        <h2 class="text-center fw-bold mt-4 mb-3">
          <%= data.title %>
        </h2>

        <img
          src="<%= data.Image.url %>"
          class="card-img-top object-fit-cover"
          style="height:380px;"
          alt="Listing Image"
        >

        <div class="card-body px-4">

          <p class="text-secondary mb-2">
            <strong>Posted By:</strong>
            <%= data.owner.username %>
          </p>

          <p class="mb-4">
            <%= data.description %>
          </p>

          <ul class="list-group list-group-flush">

            <li class="list-group-item">
              <strong>Price :</strong>
              ₹ <%= data.price.toLocaleString("en-IN") %>
            </li>

            <li class="list-group-item">
              <strong>Location :</strong>
              <%= data.location %>
            </li>

            <li class="list-group-item">
              <strong>Country :</strong>
              <%= data.country %>
            </li>

          </ul>

        </div>

        <% if(user && user._id.equals(data.owner._id)){ %>

        <div class="card-body border-top">

          <div class="d-flex justify-content-center gap-3 flex-wrap">

            <form action="/showall/<%= data.id %>/edit" method="GET">
              <button class="btn btn-dark px-4">
                Edit
              </button>
            </form>

            <form action="/showall/<%= data.id %>?_method=DELETE" method="POST">
              <button class="btn btn-outline-danger px-4">
                Delete
              </button>
            </form>

          </div>

        </div>

        <% } %>

      </div>

    </div>
  </div>



  <!-- Review Form -->

  <% if(user){ %>

  <div class="row justify-content-center mt-5">

    <div class="col-lg-8">

      <div class="card shadow border-0 rounded-4">

        <div class="card-body p-4">

          <h3 class="text-center mb-4">
            Add Review
          </h3>

          <form action="/showall/<%= data.id %>/reviews" method="POST">

            <div class="mb-4">

              <label class="form-label fw-semibold">
                Rate your experience
              </label>

              <fieldset class="starability-coinFlip">

                <input type="radio" id="no-rate"
                  class="input-no-rate"
                  name="Reviews[rating]"
                  value="0"
                  checked>

                <input type="radio" id="first-rate1" name="Reviews[rating]" value="1">
                <label for="first-rate1">1 star</label>

                <input type="radio" id="first-rate2" name="Reviews[rating]" value="2">
                <label for="first-rate2">2 stars</label>

                <input type="radio" id="first-rate3" name="Reviews[rating]" value="3">
                <label for="first-rate3">3 stars</label>

                <input type="radio" id="first-rate4" name="Reviews[rating]" value="4">
                <label for="first-rate4">4 stars</label>

                <input type="radio" id="first-rate5" name="Reviews[rating]" value="5">
                <label for="first-rate5">5 stars</label>

              </fieldset>

            </div>

            <div class="mb-4">

              <label class="form-label fw-semibold">
                Comment
              </label>

              <textarea
                class="form-control"
                rows="4"
                name="Reviews[comment]"
                required
              ></textarea>

            </div>

            <div class="text-center">

              <button class="btn btn-primary px-5">
                Submit Review
              </button>

            </div>

          </form>

        </div>

      </div>

    </div>

  </div>

  <% } %>



  <!-- Reviews -->

  <% if(data.reviews && data.reviews.length){ %>

  <div class="mt-5">

    <h3 class="text-center fw-bold mb-4">
      All Reviews
    </h3>

    <div class="row g-4">

      <% for(let review of data.reviews){ %>

      <div class="col-lg-4 col-md-6">

        <div class="card shadow-sm h-100 border-0">

          <div class="card-body">

            <h5 class="fw-bold mb-2">
              <%= review.owner.username %>
            </h5>

            <p
              class="starability-result mb-3"
              data-rating="<%= review.rating %>">
              Rated <%= review.rating %> Stars
            </p>

            <p class="card-text">
              <%= review.comment %>
            </p>

            <% if(user && review.owner._id.equals(user._id)){ %>

            <form
              action="/showall/<%= data.id %>/reviews/<%= review.id %>?_method=DELETE"
              method="POST">

              <button class="btn btn-sm btn-outline-danger">
                Delete
              </button>

            </form>

            <% } %>

          </div>

        </div>

      </div>

      <% } %>

    </div>

  </div>

  <% } %>



  <!-- Map -->

  <div class="container mt-2 mb-2 rounded-4 shadow-lg p-2 d-flex flex-column">
    <div class="text-center"><h2>Map View</h2></div>
<div id="map" class="rounded-3 w-100 text-center" style="height:450px; overflow: hidden ;"></div>
  </div>

</div>
<script>
    const mapToken = "<%= mapToken %>";
    const data = <%- JSON.stringify(data) %>;
</script>

<script src="/js/map.js"></script>